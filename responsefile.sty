% !TeX encoding = UTF-8

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{responsefile}[2026/06/11 v1.0 Academic paper response formatting]

\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{graphicx}
\RequirePackage{titlesec}
\RequirePackage{xcolor}
\RequirePackage[font=small,figurename=Fig.]{caption}
\RequirePackage{etoolbox}
\RequirePackage{mdframed}
\RequirePackage{float}
\RequirePackage{chapterbib}

\geometry{left=1in, right=1in, top=1in, bottom=1in}

\newcommand{\header}[2]{
    \begin{spacing}{1.5}
    \begin{center}
    {\LARGE\textbf{Response File}}

    to the reviewers' comments of the manuscript titled:

    {\large\textbf{#1}}

    submitted to

    {\large\textbf{#2}}
    \end{center}
    \end{spacing}
    \noindent\hrulefill
}

\newcommand{\editor}{\chapter*}

\titleformat{\chapter}
    {\normalfont\Large\bfseries}{Reviewer~\thechapter}{1em}{}
\titlespacing{\chapter}{0pt}{0ex}{2ex}
\newcommand{\reviewer}{\chapter}

\titleformat{\section}
    {\normalfont\bfseries}{R\arabic{chapter}Q\arabic{section}}{1em}{}
\titlespacing{\section}{0pt}{2ex}{1ex}

\renewcommand{\thefigure}{R\thechapter-\arabic{figure}}
\renewcommand{\thetable}{R\thechapter-\arabic{table}}

\patchcmd{\thebibliography}{\chapter*}{\section*}{}{}
\renewcommand{\bibname}{References}

\definecolor{ReviewerRed}{HTML}{B85C57}
\definecolor{AmendmentBlue}{HTML}{527DA3}
\newcommand{\amendmentfont}{\fontsize{10pt}{12pt}\selectfont}

\global\mdfdefinestyle{basestyle}{
    linewidth=4pt,
    topline=false,
    rightline=false,
    bottomline=false,
    innertopmargin=4pt,
    innerbottommargin=4pt,
    skipabove=5pt,
    skipbelow=5pt
}

\newenvironment{equestion}[1]{
    \section*{#1}
    \begin{itshape}
    \begin{mdframed}[style=basestyle, linecolor=ReviewerRed]
}
{
    \end{mdframed}
    \end{itshape}
}

\newenvironment{question}{
    \section{}
    \begin{itshape}
    \begin{mdframed}[style=basestyle, linecolor=ReviewerRed]
}
{
    \end{mdframed}
    \end{itshape}
}

\newenvironment{amendment}[2]{
    \begin{mdframed}[
        style=basestyle,
        linecolor=AmendmentBlue
    ]
    \amendmentfont
    \textit{\textbf{Revised in Section #1 titled ``#2''}}
    \\
}
{
    \end{mdframed}
}

\newenvironment{response}{
    \par\noindent\textbf{Response:~}\ignorespaces
}
{
    \par
}

\endinput
